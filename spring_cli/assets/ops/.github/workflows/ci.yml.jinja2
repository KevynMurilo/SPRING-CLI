name: CI/CD Pipeline

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main, develop ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v4

    - name: Set up JDK {{ java_version }}
      uses: actions/setup-java@v4
      with:
        java-version: '{{ java_version }}'
        distribution: 'temurin'
        cache: {% if build_tool == 'maven' %}maven{% else %}gradle{% endif %}

    {% if build_tool == 'maven' %}
    - name: Build with Maven
      run: mvn -B package --file pom.xml

    - name: Run tests
      run: mvn test

    - name: Generate coverage report
      run: mvn jacoco:report
    {% else %}
    - name: Build with Gradle
      run: ./gradlew build

    - name: Run tests
      run: ./gradlew test

    - name: Generate coverage report
      run: ./gradlew jacocoTestReport
    {% endif %}

    - name: Upload coverage to Codecov
      uses: codecov/codecov-action@v3
      with:
        file: {% if build_tool == 'maven' %}./target/site/jacoco/jacoco.xml{% else %}./build/reports/jacoco/test/jacocoTestReport.xml{% endif %}

  security-scan:
    runs-on: ubuntu-latest
    needs: build

    steps:
    - uses: actions/checkout@v4

    - name: Run Trivy vulnerability scanner
      uses: aquasecurity/trivy-action@master
      with:
        scan-type: 'fs'
        scan-ref: '.'
        format: 'sarif'
        output: 'trivy-results.sarif'

    - name: Upload Trivy results to GitHub Security
      uses: github/codeql-action/upload-sarif@v2
      with:
        sarif_file: 'trivy-results.sarif'

  docker:
    runs-on: ubuntu-latest
    needs: build
    if: github.ref == 'refs/heads/main'

    steps:
    - uses: actions/checkout@v4

    - name: Set up Docker Buildx
      uses: docker/setup-buildx-action@v3

    - name: Login to DockerHub
      uses: docker/login-action@v3
      with:
        username: ${{ secrets.DOCKERHUB_USERNAME }}
        password: ${{ secrets.DOCKERHUB_TOKEN }}

    - name: Build and push
      uses: docker/build-push-action@v5
      with:
        context: .
        push: true
        tags: ${{ secrets.DOCKERHUB_USERNAME }}/{{ project_name }}:latest
        cache-from: type=registry,ref=${{ secrets.DOCKERHUB_USERNAME }}/{{ project_name }}:buildcache
        cache-to: type=registry,ref=${{ secrets.DOCKERHUB_USERNAME }}/{{ project_name }}:buildcache,mode=max
