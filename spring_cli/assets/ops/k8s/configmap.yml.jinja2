apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ project_name }}-config
data:
  application.yml: |
    server:
      port: 8080

    management:
      endpoints:
        web:
          exposure:
            include: health,info,metrics,prometheus
      endpoint:
        health:
          probes:
            enabled: true
          show-details: when-authorized

    logging:
      level:
        root: INFO
